# 复制此文件为 .env 并填入你的 API Key

# OpenAI API (用于 AI Agent 推理)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API (备选)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PandaScore API (电竞数据)
# 注册地址: https://pandascore.co/
PANDASCORE_API_KEY=your_pandascore_token_here

# API-Football (足球数据)
# 注册地址: https://www.api-football.com/
FOOTBALL_API_KEY=your_api_football_key_here

# TheSportsDB (综合体育数据，免费)
# 注册地址: https://www.thesportsdb.com/
THESPORTSDB_API_KEY=1  # 使用测试 key，或注册获取自己的
